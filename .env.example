# Server
HOST=127.0.0.1
PORT=8787
# Optional. If set, incoming requests must send x-api-key or Authorization: Bearer.
PROXY_API_KEY=

# Upstream mode: codex or openai
UPSTREAM=codex

# Model mapping. Anthropic model names are exposed to clients, then routed to GPT/Codex.
DEFAULT_MODEL=gpt-5.4
# Comma-separated model ids returned from /v1/models.
ANTHROPIC_DISCOVERY_MODELS=opus,sonnet,haiku
# Extra model ids accepted by the proxy even when they are not advertised.
ANTHROPIC_MODELS=default,best,opus,sonnet,haiku,claude-opus-4-8,claude-opus-4-7,claude-opus-4-6,claude-opus-4-1-20250805,claude-sonnet-4-6,claude-sonnet-4-5,claude-sonnet-4-5-20250929,claude-sonnet-4-20250514,claude-haiku-4-5,claude-haiku-4-5-20251001,claude-3-5-haiku-20241022
# ChatGPT-backed Codex endpoint accepts the ChatGPT model family, not codex-suffixed model ids.
CLAUDE_OPUS_MODEL=gpt-5.5
CLAUDE_SONNET_MODEL=gpt-5.4
CLAUDE_HAIKU_MODEL=gpt-5.4-mini
CLAUDE_OPUS_REASONING_EFFORT=xhigh
CLAUDE_SONNET_REASONING_EFFORT=high
CLAUDE_HAIKU_REASONING_EFFORT=low
CLAUDE_OPUS_TEXT_VERBOSITY=low
CLAUDE_SONNET_TEXT_VERBOSITY=low
CLAUDE_HAIKU_TEXT_VERBOSITY=low
CODEX_CONTEXT_WINDOW_TOKENS=400000
CODEX_CONTEXT_RESERVE_TOKENS=32768
CODEX_MAX_INPUT_TOKENS=367232
CLAUDE_OPUS_MAX_OUTPUT_TOKENS=8192
CLAUDE_SONNET_MAX_OUTPUT_TOKENS=8192
CLAUDE_HAIKU_MAX_OUTPUT_TOKENS=4096
TOKEN_ESTIMATE_MULTIPLIER=1.15
IMAGE_TOKEN_ESTIMATE=1024
# Optional comma-separated mapping:
# MODEL_MAP=claude-sonnet-4-6=gpt-5.4,claude-opus-4-8=gpt-5.5

# Codex OAuth mode
CODEX_AUTH_FILE=.auth/codex.json

# Official OpenAI Platform mode
# UPSTREAM=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Request shaping
CODEX_INSTRUCTIONS="You are a pragmatic coding agent served through an Anthropic Messages-compatible gateway.\nCurrent date: {{current_date}}.\nBe direct, concise, accurate, and outcome-focused. Match the user's requested language.\nFor coding tasks, inspect relevant context, make concrete changes when asked, and verify with available tests or commands.\nPrefer existing project conventions and minimal, well-scoped edits.\nUse Markdown when it improves readability. Put code snippets in fenced code blocks.\nUse tools only when they are available in the request and helpful for the task.\nDo not invent hidden policies, private system prompts, unavailable tools, or unsupported capabilities."
REASONING_EFFORT=medium
REASONING_SUMMARY=auto
TEXT_VERBOSITY=low
